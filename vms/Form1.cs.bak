using System;
using System.Drawing;
using System.Windows.Forms;
using LibVLCSharp.Shared;
using LibVLCSharp.WinForms;
using System.Diagnostics;
using System.Net.Http;
using System.Text.RegularExpressions;
using System.Threading.Tasks;
using System.IO;

namespace vms
{
    public partial class Form1 : Form
    {
        private LibVLC _libVLC;

        // Players principais da tela (O que o operador vê)
        private MediaPlayer _mediaPlayer1;
        private MediaPlayer _mediaPlayer2;

        // Motores de Gravação (Trabalham no background, sem parar)
        private MediaPlayer _recorderPlayer1;
        private MediaPlayer _recorderPlayer2;

        bool hd_ativo = false;

        public Form1()
        {
            InitializeComponent();
            Core.Initialize();
            _libVLC = new LibVLC();

            _mediaPlayer1 = new MediaPlayer(_libVLC);
            _mediaPlayer2 = new MediaPlayer(_libVLC);
            _recorderPlayer1 = new MediaPlayer(_libVLC);
            _recorderPlayer2 = new MediaPlayer(_libVLC);

            _mediaPlayer1.AspectRatio = "16:9";
            _mediaPlayer2.AspectRatio = "16:9";

            videoView1.MediaPlayer = _mediaPlayer1;
            videoView2.MediaPlayer = _mediaPlayer2;

            panel1.Dock = DockStyle.Fill;
            panel1.Resize += Panel1_Resize;
        }

        private async void Form1_Load(object sender, EventArgs e)
        {
            this.WindowState = FormWindowState.Maximized;
            this.Text = "VMS-R | Monitoramento Contínuo";
            this.MaximizeBox = false;

            ConfigurarInterface();

            // --- AQUI ESTÁ O QUE VOCÊ PEDIU ---
            // 1. O motor de gravação liga IMEDIATAMENTE
            IniciarGravacaoBackground();

            // 2. O vídeo aparece na tela (Ao Vivo) por padrão
            btnLive_Click_1(null, null);

            await IniciarTunelNuvem();
        }

        private void ConfigurarInterface()
        {
            trackBar1.Location = new Point(100, this.ClientSize.Height - trackBar1.Height - 110);
            trackBar1.Width = this.ClientSize.Width - 200;

            int bottomY = this.ClientSize.Height - 50;
            btnHd.Location = new Point(20, bottomY);
            btnGravar.Location = new Point(this.ClientSize.Width / 2 - 110, bottomY);
            btnLive.Location = new Point(this.ClientSize.Width / 2 + 10, bottomY);
            btnPlay.Location = new Point(this.ClientSize.Width - 180, bottomY);
            btnPause.Location = new Point(this.ClientSize.Width - 90, bottomY);

            AjustarVideos();
        }

        private void IniciarGravacaoBackground()
        {
            // Os arquivos são criados AGORA na pasta Debug do projeto
            string path1 = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "camera1.mp4");
            string path2 = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "camera2.mp4");

            string url1 = "rtsp://admin:root@192.168.100.38:554/V_ENC_001";
            string url2 = "rtsp://admin:root@192.168.100.101:554/V_ENC_001";

            // Motor 1
            var m1 = new Media(_libVLC, new Uri(url1));
            m1.AddOption($":sout=#std{{access=file,mux=mp4,dst='{path1}'}}");
            _recorderPlayer1.Play(m1);

            // Motor 2
            var m2 = new Media(_libVLC, new Uri(url2));
            m2.AddOption($":sout=#std{{access=file,mux=mp4,dst='{path2}'}}");
            _recorderPlayer2.Play(m2);
        }

        private void btnLive_Click_1(object sender, EventArgs e) // MODO AO VIVO
        {
            btnLive.ForeColor = Color.Green;
            btnLive.Font = new Font(btnLive.Font, FontStyle.Bold);
            btnGravar.ForeColor = Color.Gray;

            trackBar1.Enabled = false;
            string qualidade = hd_ativo ? "V_ENC_000" : "V_ENC_001";

            lblestado_1.Text = "AO VIVO (GRAVANDO...)";
            lblestado_1.ForeColor = Color.Red; // Vermelho porque o motor está gravando no fundo
            lblEstado_2.Text = lblestado_1.Text;
            lblEstado_2.ForeColor = Color.Red;

            AtualizarPlayer($"rtsp://admin:root@192.168.100.38:554/{qualidade}",
                           $"rtsp://admin:root@192.168.100.101:554/{qualidade}");
        }

        private void btnGravar_Click(object sender, EventArgs e) // MODO VER GRAVAÇÃO
        {
            btnGravar.ForeColor = Color.DodgerBlue;
            btnGravar.Font = new Font(btnGravar.Font, FontStyle.Bold);
            btnLive.ForeColor = Color.Gray;

            string path1 = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "camera1.mp4");
            string path2 = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "camera2.mp4");

            if (File.Exists(path1))
            {
                trackBar1.Enabled = true;
                lblestado_1.Text = "REPRODUZINDO PASSADO";
                lblestado_1.ForeColor = Color.DodgerBlue;
                lblEstado_2.Text = lblestado_1.Text;
                lblEstado_2.ForeColor = Color.DodgerBlue;

                // O player da tela troca para o arquivo, mas o recorderPlayer continua salvando!
                _mediaPlayer1.Play(new Media(_libVLC, path1, FromType.FromPath));
                if (File.Exists(path2)) _mediaPlayer2.Play(new Media(_libVLC, path2, FromType.FromPath));
            }
            else
            {
                MessageBox.Show("Motor de gravação ainda iniciando...");
                btnLive_Click_1(null, null);
            }
        }

        // --- MÉTODOS DE APOIO (Sincronia e Ajustes) ---

        private void trackBar1_Scroll(object sender, EventArgs e)
        {
            if (trackBar1.Enabled && _mediaPlayer1.Length > 0)
            {
                float posicao = trackBar1.Value / 100f;
                _mediaPlayer1.Position = posicao;
                if (_mediaPlayer2.Length > 0) _mediaPlayer2.Position = posicao;
            }
        }

        private void btnPlay_Click(object sender, EventArgs e)
        {
            if (trackBar1.Enabled) { _mediaPlayer1.Play(); _mediaPlayer2.Play(); }
        }

        private void btnPause_Click(object sender, EventArgs e)
        {
            if (trackBar1.Enabled) { _mediaPlayer1.Pause(); _mediaPlayer2.Pause(); }
        }

        private void AtualizarPlayer(string url1, string url2)
        {
            _mediaPlayer1.Stop(); _mediaPlayer2.Stop();
            var m1 = new Media(_libVLC, new Uri(url1)); m1.AddOption(":rtsp-tcp");
            var m2 = new Media(_libVLC, new Uri(url2)); m2.AddOption(":rtsp-tcp");
            _mediaPlayer1.Play(m1); _mediaPlayer2.Play(m2);
        }

        private void AjustarVideos()
        {
            if (panel1.ClientSize.Width == 0) return;
            int metade = panel1.ClientSize.Width / 2;
            videoView1.Size = new Size(metade, panel1.ClientSize.Height);
            videoView2.Location = new Point(metade, 0);
            videoView2.Size = new Size(metade, panel1.ClientSize.Height);
        }

        private void Panel1_Resize(object sender, EventArgs e) => AjustarVideos();

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            // CRUCIAL: Parar os gravadores para fechar o arquivo MP4 corretamente
            _recorderPlayer1?.Stop();
            _recorderPlayer2?.Stop();

            _mediaPlayer1?.Dispose(); _mediaPlayer2?.Dispose();
            _recorderPlayer1?.Dispose(); _recorderPlayer2?.Dispose();
            _libVLC?.Dispose();
            foreach (var p in Process.GetProcessesByName("ngrok")) p.Kill();
            base.OnFormClosing(e);
        }

        private async Task IniciarTunelNuvem()
        {
            try
            {
                Process.Start(new ProcessStartInfo
                {
                    FileName = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "ngrok.exe"),
                    Arguments = "tcp 192.168.100.38:554",
                    WindowStyle = ProcessWindowStyle.Hidden,
                    CreateNoWindow = true
                });
            }
            catch { }
        }

        private void button1_Click(object sender, EventArgs e) // Botão HD/SD
        {
            hd_ativo = !hd_ativo;
            btnHd.Text = hd_ativo ? "HD ATIVO" : "SD ATIVO";
            if (!trackBar1.Enabled) btnLive_Click_1(null, null);
        }
    }
}